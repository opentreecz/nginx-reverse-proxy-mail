# Copy this file to .env and adjust the values for your environment.
# See docs/configuration.md for a full description of every variable.

#### General ##################################################################

# Primary domain name served by this proxy (used for the default HTTPS vhost
# and as the first name on the Let's Encrypt certificate).
DOMAIN=example.com

# Additional hostnames to include as SANs on the same certificate AND in
# nginx's server_name directive. Space separated (nginx server_name syntax).
EXTRA_DOMAINS=www.example.com mail.example.com webmail.example.com autoconfig.example.com autodiscover.example.com admin.example.com

# Contact address passed to Let's Encrypt for expiry/urgent notices.
LETSENCRYPT_EMAIL=admin@example.com

# Set to 1 while testing so certbot uses the Let's Encrypt staging endpoint
# (much higher rate limits, but the certificate is not trusted by clients).
LETSENCRYPT_STAGING=0

# Local timezone for logs and cron-style renewal scheduling.
TZ=UTC

#### nginx runtime #############################################################

NGINX_WORKER_PROCESSES=auto
# How often the container proactively reloads nginx so renewed
# Let's Encrypt certificates are picked up without a restart.
NGINX_RELOAD_INTERVAL=12h

#### Mail backends (behind the proxy, plaintext on the internal network) ######

SMTP_BACKEND=postfix:25
SMTP_SUBMISSION_BACKEND=postfix:587
SMTPS_BACKEND=postfix:25
IMAP_BACKEND=dovecot:143
IMAPS_BACKEND=dovecot:143
POP3_BACKEND=dovecot:110
POP3S_BACKEND=dovecot:110

#### Usenet (NNTP) backend #####################################################

NNTP_BACKEND=nntp-server:119
NNTPS_BACKEND=nntp-server:119

#### XMPP backend ###############################################################

XMPP_CLIENT_BACKEND=prosody:5222
XMPPS_CLIENT_BACKEND=prosody:5222
XMPP_SERVER_BACKEND=prosody:5269

#### HTTP(S) backends ###########################################################

# Backend for plain HTTP (port 80 only serves ACME challenges + redirects to HTTPS).
HTTP_BACKEND=webapp:8080
# Backend for the main HTTPS vhost (port 443).
HTTPS_BACKEND=webapp:8080
# Backend for the secondary/admin HTTPS vhost (port 8443).
ADMIN_HTTPS_BACKEND=admin-webapp:8443

#### Custom / additional TCP services ##########################################

# Free-form TCP passthrough slots for the two non-standard ports requested in
# the project spec. Point them at whatever service actually listens there.
CUSTOM_TCP_1_PORT=4040
CUSTOM_TCP_1_BACKEND=custom-service-1:4040
CUSTOM_TCP_2_PORT=44337
CUSTOM_TCP_2_BACKEND=custom-service-2:44337
